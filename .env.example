DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret-key
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Use sqlite for simple hosting, or set DATABASE_ENGINE=mysql and fill MySQL values.
DATABASE_ENGINE=sqlite
SQLITE_PATH=db.sqlite3

# DATABASE_ENGINE=mysql
# MYSQL_DATABASE=nifty_intel
# MYSQL_USER=root
# MYSQL_PASSWORD=replace-this-password
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
